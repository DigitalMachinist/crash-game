{
  "name": "crash-game",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev:server": "wrangler dev",
    "dev:client": "vite",
    "build:client": "vite build",
    "test": "vitest run",
    "test:svelte": "vitest run --config vitest.svelte.config.ts",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "test:all": "npm run test && npm run test:svelte && npm run test:workers",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --project tsconfig.server.json --noEmit",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "check": "biome check src",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "partyserver": "^0.3.3",
    "partysocket": "^1.1.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260310.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "~3.2.4",
    "fast-check": "^4.6.0",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.3.3",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.53.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "~3.2.4",
    "wrangler": "^4.72.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,svelte}": [
      "biome check --write --no-errors-on-unmatched",
      "git add"
    ]
  }
}
